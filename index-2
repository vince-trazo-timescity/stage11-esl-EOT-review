     JAVASCRIPT DATA & LOGIC (UPDATED FOR GLOBAL FOOD CRISIS)
     ==================================================== -->
<script>
// =====================================================
// DATA (updated WRITING_TASKS + MODEL ANSWER)
// =====================================================
const UNITS = [ /* your original UNITS array — unchanged */ ];

const WRITING_TASKS = [
  /* ... all other writing tasks unchanged ... */
  {
    unit: "Unit 9 — The Environment", type: "Formal Report",
    color: "#0277BD", len: "200–250 words",
    prompts: [
      "A) Write a report on the main causes and effects of air pollution in your city or country.",
      "B) Write a report on the water shortage crisis — causes, effects, and possible solutions.",
      "C) Write a report on how deforestation is affecting biodiversity around the world.",
      "D) Write a report on the global food crisis — causes, effects, and possible solutions. (Use Unit 10 vocabulary)"
    ],
    structure: ["Title: 'Report on [Topic]'", "Introduction — state purpose: 'This report aims to…'", "Causes / Background (heading)", "Effects / Findings (heading)", "Recommendations (heading)", "Conclusion — summary + call to action"],
    tips: [ /* your original tips unchanged */ ],
    dos: [ /* your original DOs unchanged */ ],
    donts: [ /* your original DON'Ts unchanged */ ],
    checklist: [ /* your original checklist unchanged */ ]
  }
  /* ... rest of WRITING_TASKS unchanged ... */
];

// === NEW: MODEL ANSWER (Global Food Crisis using Unit 10 vocab) ===
const MODEL_ANSWERS = {
  "Formal Report": `
    <h3 style="color:#0277BD;margin-bottom:12px;">📋 Model Answer – Report on the Global Food Crisis (238 words)</h3>
    <div style="background:#f0f4f8;padding:20px;border-radius:12px;border-left:6px solid #0277BD;line-height:1.65;font-size:0.95rem;">
      <strong>Report on the Global Food Crisis</strong><br><br>
      This report aims to examine the main causes and effects of the global food crisis and to propose viable solutions.<br><br>
      <strong>Causes / Background</strong><br>
      Several interconnected factors have contributed to the crisis. Monoculture farming practices have depleted soil nutrients and reduced biodiversity. Furthermore, the overuse of pesticides has polluted waterways and harmed ecosystems. Climate change has intensified droughts and floods, disrupting supply chains and increasing food miles. In addition, rising global consumption of meat and processed food has accelerated deforestation.<br><br>
      <strong>Effects / Findings</strong><br>
      These developments have revealed serious consequences. Food security remains a major challenge for developing nations. It has been estimated that hundreds of millions of people lack reliable access to sufficient, nutritious food. Moreover, higher prices have led to increased consumption of processed food, which often contains high levels of salt and sugar.<br><br>
      <strong>Recommendations</strong><br>
      Governments should invest in sustainable farming methods such as organic farming and hydroponics. Consumers must support fair trade initiatives and adopt localvore diets to reduce food miles. Genetically modified crops resistant to drought could be promoted responsibly where appropriate.<br><br>
      <strong>Conclusion</strong><br>
      In conclusion, the global food crisis threatens both human wellbeing and environmental stability. Urgent coordinated action through sustainable practices is therefore essential to achieve long-term food security for future generations.
    </div>
    <p style="font-size:0.82rem;color:#2E7D32;margin-top:12px;">✅ Uses 12+ Unit 10 words • Follows every DO/DON'T & checklist item</p>
  `
};

// =====================================================
// PRACTICE TASK SELECTION (UPDATED)
// =====================================================
function selectPracticeTask(index) {
  currentPracticeTask = index;
  var task = WRITING_TASKS[index];
  document.getElementById('practiceSelect').style.display = 'none';
  document.getElementById('practiceWork').style.display = '';
  document.getElementById('practiceFeedbackPanel').style.display = 'none';

  var banner = document.getElementById('practiceBanner');
  banner.style.background = task.color;
  document.getElementById('practiceBannerUnit').textContent = task.unit;
  document.getElementById('practiceBannerType').textContent = task.type;
  document.getElementById('practiceBannerLen').textContent = 'Target: ' + task.len;

  var prompt = task.prompts[Math.floor(Math.random() * task.prompts.length)];
  document.getElementById('practiceBannerPrompt').textContent = prompt;
  document.getElementById('practiceQuickTipsText').textContent = QUICK_TIPS[task.type] || '';

  document.getElementById('practiceTextarea').value = '';
  updateWordCount();

  // === SHOW MODEL ANSWER BUTTON FOR FORMAL REPORT ===
  let existingBtn = document.getElementById('modelAnswerBtn');
  if (existingBtn) existingBtn.remove();
  if (task.type === "Formal Report") {
    const btnHTML = `<button class="btn btn-outline btn-sm" id="modelAnswerBtn" onclick="showModelAnswer()" style="margin-left:12px;">📋 View Model Answer (Global Food Crisis)</button>`;
    document.querySelector('.practice-meta div').insertAdjacentHTML('beforeend', btnHTML);
  }
  window.scrollTo(0, 0);
}

// === NEW FUNCTION: Show Model Answer ===
function showModelAnswer() {
  const panel = document.getElementById('practiceFeedbackPanel');
  panel.style.display = '';
  panel.innerHTML = MODEL_ANSWERS["Formal Report"] + 
    `<div style="text-align:center;margin-top:20px;">
      <button class="btn btn-primary" onclick="document.getElementById('practiceFeedbackPanel').style.display='none'">✏️ Close Model & Keep Writing</button>
    </div>`;
  panel.scrollIntoView({ behavior: 'smooth' });
}

