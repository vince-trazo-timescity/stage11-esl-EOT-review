}
function toggleCheck(id, label) {
  const cb = label.querySelector('input');
  cb.checked = !cb.checked;
  label.classList.toggle('checked', cb.checked);
  const parts = id.split('-');
  const ti = parts[0];
  if (!activeChecklist[ti]) activeChecklist[ti] = {};
  activeChecklist[ti][id] = cb.checked;
  const total = WRITING_TASKS[ti].checklist.length;
  const done  = Object.values(activeChecklist[ti]).filter(Boolean).length;
  document.getElementById(`clBar-${ti}`).style.width = (done/total*100) + "%";
  document.getElementById(`clPct-${ti}`).textContent = `${done} / ${total} complete`;
  if (done === total) {
    showToast("Checklist complete! +20 XP 🌟", "green");
    addXP(20);
  }
}

