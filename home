function parseWordRange(lenStr) {
  var m = lenStr.match(/(\d+)[\u2013\-](\d+)/);
  if (m) return [parseInt(m[1]), parseInt(m[2])];
  return [150, 250];
}

function updateWordCount() {
  var text  = document.getElementById('practiceTextarea').value.trim();
  var count = text.length === 0 ? 0 : text.split(/\s+/).filter(function(w) { return w.length > 0; }).length;
  var task  = WRITING_TASKS[currentPracticeTask];
  var range = parseWordRange(task.len);
  var min = range[0], max = range[1];
  var el = document.getElementById('wcDisplay');
  el.textContent = count + ' / ' + min + '–' + max + ' words';
  if (count === 0)          el.style.color = '#94A3B8';
  else if (count < min*0.6) el.style.color = '#C62828';
  else if (count < min)     el.style.color = '#E07B39';
  else if (count <= max)    el.style.color = '#2E7D32';
  else                      el.style.color = '#E07B39';
}

// ── MAIN ANALYSIS FUNCTION ──────────────────────────
function analyzeWriting() {
  var text = document.getElementById('practiceTextarea').value.trim();
  if (!text || text.split(/\s+/).length < 15) {
    showToast('Write a little more before analysing!', ''); return;
  }
  var task    = WRITING_TASKS[currentPracticeTask];
  var lText   = text.toLowerCase();
  var words   = text.split(/\s+/).filter(function(w) { return w.length > 0; });
  var wCount  = words.length;
  var range   = parseWordRange(task.len);
  var minW = range[0], maxW = range[1];

  // ── 1. Word Count (20 pts) ──
  var wcScore, wcStatus, wcMsg;
  if (wCount < minW * 0.5) {
    wcScore = 5; wcStatus = 'red';
    wcMsg = 'Too short (' + wCount + ' words). Aim for at least ' + minW + ' words to develop your ideas fully.';
  } else if (wCount < minW) {
    wcScore = 12; wcStatus = 'amber';
    wcMsg = 'Nearly there! You have ' + wCount + ' words. Try to reach the minimum of ' + minW + '.';
  } else if (wCount <= maxW) {
    wcScore = 20; wcStatus = 'green';
    wcMsg = 'Word count is within the target range (' + wCount + ' words). Well done!';
  } else {
    wcScore = 14; wcStatus = 'amber';
    wcMsg = 'Slightly over the limit (' + wCount + ' words). Try to trim to ' + maxW + ' for a tighter piece.';
  }

  // ── 2. Linking Devices (20 pts) ──
  var foundLinkers = [];
  ALL_LINKERS_FLAT.forEach(function(l) {
    var lw = l.w.toLowerCase();
    if (lText.indexOf(lw) !== -1 && foundLinkers.indexOf(l.w) === -1) foundLinkers.push(l.w);
  });
  var linkerTarget = task.type === 'Opinion Essay' ? 5 : task.type === 'Informal Letter' ? 4 : 3;
  var linkerScore  = Math.min(20, Math.round((foundLinkers.length / linkerTarget) * 20));
  var usedCats = {};
  ALL_LINKERS_FLAT.forEach(function(l) { if (foundLinkers.indexOf(l.w) !== -1) usedCats[l.cat] = true; });
  var missingCats = Object.keys(LINKER_CATS_DISPLAY).filter(function(k) { return !usedCats[k]; })
                          .map(function(k) { return LINKER_CATS_DISPLAY[k]; });

  // ── 3. Unit Vocabulary (20 pts) ──
  var unitMatch = UNITS.find(function(u) { return u.writing === task.type; });
  var foundVocab = [], unusedVocab = [];
  if (unitMatch) {
    unitMatch.vocab.forEach(function(v) {
      if (lText.indexOf(v.w.toLowerCase()) !== -1) foundVocab.push(v.w);
      else unusedVocab.push(v);
    });
    unusedVocab = unusedVocab.slice(0, 4);
  }
  var vocabTarget = task.type === 'Informal Letter' ? 5 : 3;
  var vocabScore  = Math.min(20, Math.round((foundVocab.length / vocabTarget) * 20));

  // ── 4. Language Register (20 pts) ──
  var regResult = checkRegisterAdvanced(text, lText, task.type);

  // ── 5. Structure (20 pts) ──
  var strResult = checkStructureAdvanced(text, lText, task);

  // ── Totals ──
  var total = wcScore + linkerScore + vocabScore + regResult.score + strResult.score;
  var grade = total >= 85 ? 'A' : total >= 70 ? 'B' : total >= 55 ? 'C' : 'D';
  var gradeColor = total >= 85 ? '#2E7D32' : total >= 70 ? '#1565C0' : total >= 55 ? '#E07B39' : '#C62828';
  var earnedXP = Math.max(5, Math.round(total / 5));
  addXP(earnedXP);
  showToast('+' + earnedXP + ' XP for your writing! ✍️', 'green');

  displayFeedback({
    task: task, wCount: wCount, minW: minW, maxW: maxW,
    wcScore: wcScore, wcMsg: wcMsg, wcStatus: wcStatus,
    foundLinkers: foundLinkers, linkerScore: linkerScore, linkerTarget: linkerTarget, missingCats: missingCats,
    foundVocab: foundVocab, vocabScore: vocabScore, vocabTarget: vocabTarget, unusedVocab: unusedVocab,
    reg: regResult, str: strResult,
    total: total, grade: grade, gradeColor: gradeColor, earnedXP: earnedXP
  });
}

// ── REGISTER CHECKER ────────────────────────────────
function checkRegisterAdvanced(text, lText, type) {
  var score = 0, good = [], issues = [];

  function pass(msg) { good.push(msg); }
  function fail(msg, fix) { issues.push(fix ? msg + ' → ' + fix : msg); }

  if (type === 'Formal Essay') {
    if (!/\b(i'm|it's|don't|can't|won't|didn't|wouldn't|couldn't|i've|i'd)\b/i.test(text)) {
      pass('No contractions — excellent formal register!'); score += 7;
    } else {
      fail('Contractions found (e.g. "I\'m" / "don\'t")', 'Use full forms: I am / do not / cannot / would not');
    }
    if (/\b(it is clear|it could be argued|evidence suggests|it is evident|it is widely acknowledged)\b/i.test(lText)) {
      pass('Formal academic phrases used ("It could be argued…" / "Evidence suggests…")'); score += 7;
    } else {
      fail('No formal academic phrases found', 'Add: "It could be argued that…" / "Evidence suggests that…"');
    }
    if (/\b(who|which|that)\b.{5,60}\b(is|are|was|were|has|have)\b/i.test(text) ||
        /,\s*(who|which)\s+/i.test(text)) {
      pass('Relative clause detected — good grammatical variety!'); score += 6;
    } else {
      fail('No relative clause detected', 'Add one: "…organisations which help communities…" or "…students who volunteer…"');
    }
  }

  else if (type === 'Blog Entry') {
    if (/\b(I|me|my)\b/.test(text)) { pass('Personal pronouns used — suits a blog\'s personal tone'); score += 5; }
    else { fail('No personal pronouns found', 'Use "I / me / my" — blogs are personal and engaging'); }
    if (/\b(extraordinary|remarkable|inspiring|courageous|incredible|pioneering|exceptional|outstanding)\b/i.test(lText)) {
      pass('Vivid descriptive vocabulary used'); score += 7;
    } else {
      fail('Limited descriptive vocabulary', 'Use stronger adjectives: extraordinary / remarkable / pioneering / exceptional');
    }
    if (/\b(firstly|moreover|furthermore|in conclusion|finally|having said that|to conclude)\b/i.test(lText)) {
      pass('Discourse markers used to structure the blog entry'); score += 8;
    } else {
      fail('No discourse markers found', 'Add: "Firstly, …" / "Moreover, …" / "In conclusion, …"');
    }
  }

  else if (type === 'Informal Letter') {
    if (/\b(i'm|it's|don't|can't|won't|didn't|i've|you're|that's|we're)\b/i.test(text)) {
      pass('Contractions used naturally — great informal tone!'); score += 8;
    } else {
      fail('No contractions found — informal letters should use them!', 'Use: I\'m / can\'t / it\'s / didn\'t / you\'re');
    }
    if (/\b(to be honest|you won't believe|guess what|by the way|anyway|oh and|speaking of)\b/i.test(lText)) {
      pass('Informal expressions used — sounds natural!'); score += 6;
    } else {
      fail('No informal expressions found', 'Try: "To be honest, …" / "You won\'t believe it, but…" / "By the way, …"');
    }
    if (/\bdear\s+sir\b|\bdear\s+madam\b|\bto whom it may concern\b/i.test(lText)) {
      fail('"Dear Sir/Madam" — this is too formal for a personal letter!', 'Use: "Hi [Name]!" or "Hey [Name],"');
    } else {
      pass('No over-formal greeting — appropriate register!'); score += 6;
    }
  }

  else if (type === 'Opinion Essay') {
    if (/\b(in my opinion|in my view|i strongly (argue|believe)|from my perspective|i believe that)\b/i.test(lText)) {
      pass('Opinion expressed clearly and directly'); score += 8;
    } else {
      fail('No opinion expression found', 'Add: "In my opinion, …" / "I strongly argue that…" in your introduction');
    }
    if (/\b(should|must|ought to|have to|need to)\b/i.test(lText)) {
      pass('Modal verbs used to express necessity and opinion'); score += 6;
    } else {
      fail('No modal verbs found', 'Use: should / must / ought to / need to');
    }
    if (/\b(for example|for instance|such as|specifically|to illustrate)\b/i.test(lText)) {
      pass('Examples given to support your arguments'); score += 6;
    } else {
      fail('No examples given — arguments need evidence', 'Add: "For example, …" or "For instance, …"');
    }
  }

  else if (type === 'Formal Report') {
    var hasPersonal = /\bI\s+(think|feel|believe|want|like|would)\b/i.test(text);
    var hasPronouns = /\b(I|we|our|us)\b/.test(text);
    if (!hasPronouns) {
      pass('No personal pronouns — excellent objective, impersonal tone!'); score += 8;
    } else if (hasPersonal) {
      fail('"I think/feel/believe" found — reports must be objective', 'Use: "The data suggests…" / "It appears that…" / "It is recommended that…"');
    } else {
      fail('Personal pronouns found — formal reports use third person', 'Replace "we" → "the report" / "I" → "it is"');
    }
    if (/\b(is being|are being|was found|were recorded|has been shown|has been estimated|it has been)\b/i.test(lText)) {
      pass('Passive voice used — perfect for a formal, objective report!'); score += 7;
    } else {
      fail('No passive voice found', 'Add: "It has been found that…" / "Forests are being destroyed…" / "Levels were recorded…"');
    }
    if (/\b(indicate|suggest|reveal|demonstrate|highlight|show)\b/i.test(lText)) {
      pass('Reporting verbs used (indicate / suggest / reveal)'); score += 5;
    } else {
      fail('No reporting verbs found', 'Use: "The data indicates / suggests / reveals that…"');
    }
  }

  else if (type === 'Magazine Article') {
    if (/[?!]/.test(text)) {
      pass('Rhetorical questions or exclamations add engagement'); score += 6;
    } else {
      fail('No rhetorical questions or exclamations', 'Add a hook like: "Did you know that…?" or "The truth is shocking!"');
    }
    if (/\b(shocking|staggering|alarming|remarkable|surprising|extraordinary|compelling|urgent|devastating)\b/i.test(lText)) {
      pass('Impactful, engaging vocabulary used'); score += 7;
    } else {
      fail('Language could be more impactful', 'Use: shocking / staggering / alarming / remarkable / extraordinary');
    }
    var sentences = text.split(/[.!?]+/).filter(function(s) { return s.trim().length > 0; });
    var lengths   = sentences.map(function(s) { return s.trim().split(/\s+/).length; });
    if (lengths.length > 2 && (Math.max.apply(null,lengths) - Math.min.apply(null,lengths)) > 5) {
      pass('Varied sentence lengths — creates good rhythm and pace'); score += 7;
    } else {
      fail('Sentences seem similar in length', 'Mix short punchy sentences with longer detailed ones for impact');
    }
  }

  return { score: Math.min(20, score), good: good, issues: issues };
}

// ── STRUCTURE CHECKER ───────────────────────────────
function checkStructureAdvanced(text, lText, task) {
  var found = [], missing = [];

  task.structure.forEach(function(element) {
    var el = element.toLowerCase();
    var detected = false;

    if (el.indexOf('introduction') !== -1 || el.indexOf('hook') !== -1 || el.indexOf('opening') !== -1) {
      detected = text.split('\n')[0].trim().length > 20;
    } else if (el.indexOf('conclusion') !== -1 || el.indexOf('conclud') !== -1 || el.indexOf('final thought') !== -1) {
      detected = /\b(in conclusion|to conclude|in summary|overall|to summarise|finally)\b/i.test(lText);
    } else if (el.indexOf('thesis') !== -1 || el.indexOf('opinion clearly') !== -1) {
      detected = /\b(in my opinion|i believe|i argue|it is clear|this essay|the aim)\b/i.test(lText);
    } else if (el.indexOf('body paragraph') !== -1 || el.indexOf('argument') !== -1) {
      detected = /\b(firstly|furthermore|in addition|moreover|secondly|additionally)\b/i.test(lText) ||
                 text.split('\n').filter(function(l){ return l.trim().length > 0; }).length > 3;
    } else if (el.indexOf('greeting') !== -1) {
      detected = /\b(hi|hey|dear)\s+\w+[,!]/i.test(text);
    } else if (el.indexOf('sign-off') !== -1 || el.indexOf('see you') !== -1) {
      detected = /\b(love|best wishes|see you|take care|lots of love|yours|hugs|cheers|all the best)\b/i.test(lText);
    } else if (el.indexOf('title') !== -1 || el.indexOf('headline') !== -1) {
      var firstLine = text.split('\n')[0].trim();
      detected = firstLine.length > 5 && firstLine.length < 100 && !firstLine.endsWith('.');
    } else if (el.indexOf('heading') !== -1 || el.indexOf('recommendation') !== -1 || el.indexOf('findings') !== -1 || el.indexOf('causes') !== -1) {
      detected = /\b(introduction|background|findings|causes|effects|recommendations|conclusion)\b/i.test(text);
    } else if (el.indexOf('impact') !== -1 || el.indexOf('legacy') !== -1) {
      detected = /\b(impact|legacy|influence|achievement|contribution|changed|inspired)\b/i.test(lText);
    } else if (el.indexOf('background') !== -1 || el.indexOf('narrative') !== -1) {
      detected = /\b(born|grew up|started|began|founded|achieved|won|overcame|discovered)\b/i.test(lText);
    } else if (el.indexOf('question') !== -1) {
      detected = /\?/.test(text);
    } else if (el.indexOf('passive') !== -1) {
      detected = /\b(is being|are being|was found|were recorded|has been shown)\b/i.test(lText);
    } else {
      detected = true; // give benefit of the doubt for complex/optional elements
    }

    if (detected) found.push(element);
    else missing.push('Add: ' + element);
  });

  var score = task.structure.length > 0
    ? Math.min(20, Math.round((found.length / task.structure.length) * 20))
    : 20;

  return { score: score, found: found, missing: missing };
}

// ── FEEDBACK RENDERER ───────────────────────────────
function feedbackCatHTML(title, score, borderColor, good, issues) {
  var bgColor = score >= 16 ? '#E8F5E9' : score >= 10 ? '#FFF3E0' : '#FFEBEE';
  var txtColor = score >= 16 ? '#2E7D32' : score >= 10 ? '#E07B39' : '#C62828';
  var goodHtml = good.map(function(g) {
    return '<div style="padding:5px 0 5px 22px;color:#1B5E20;font-size:0.83rem;position:relative;"><span style="position:absolute;left:0;">✔</span>' + g + '</div>';
  }).join('');
  var issHtml = issues.map(function(i) {
    return '<div style="padding:5px 0 5px 22px;color:#B71C1C;font-size:0.83rem;position:relative;"><span style="position:absolute;left:0;">✘</span>' + i + '</div>';
  }).join('');
  return '<div style="background:white;border-radius:14px;padding:18px 22px;margin-bottom:14px;box-shadow:var(--shadow);border-left:5px solid ' + borderColor + ';">' +
    '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">' +
    '<div style="font-size:0.95rem;font-weight:800;color:var(--dark);">' + title + '</div>' +
    '<div style="background:' + bgColor + ';color:' + txtColor + ';font-weight:800;font-size:0.85rem;padding:4px 12px;border-radius:12px;">' + score + ' / 20</div>' +
    '</div>' + goodHtml + issHtml + '</div>';
}

function displayFeedback(d) {
  var panel = document.getElementById('practiceFeedbackPanel');
  panel.style.display = '';

  var gradeEmoji = d.grade === 'A' ? '🌟' : d.grade === 'B' ? '👍' : d.grade === 'C' ? '💪' : '📖';
  var gradeMsg   = d.grade === 'A' ? 'Outstanding work!' : d.grade === 'B' ? 'Well done!' :
                   d.grade === 'C' ? 'Good effort — keep improving!' : 'More practice needed — review the tips above';

  var scCats = [
    { lbl: 'Words', s: d.wcScore },
    { lbl: 'Linkers', s: d.linkerScore },
    { lbl: 'Vocab', s: d.vocabScore },
    { lbl: 'Register', s: d.reg.score },
    { lbl: 'Structure', s: d.str.score }
  ];
  var catsHtml = scCats.map(function(c) {
    var col = c.s >= 16 ? '#2E7D32' : c.s >= 10 ? '#E07B39' : '#C62828';
    return '<div class="score-mini-cat"><div class="score-mini-num" style="color:' + col + ';">' + c.s + '/20</div>' +
           '<div class="score-mini-lbl">' + c.lbl + '</div></div>';
  }).join('');

  // Linker positives/issues
  var linkerGood = d.foundLinkers.length > 0
    ? ['Found ' + d.foundLinkers.length + ' linking device(s): <b>' + d.foundLinkers.join(', ') + '</b>']
    : [];
  var linkerIss  = d.foundLinkers.length < d.linkerTarget
    ? ['Need at least ' + d.linkerTarget + '. Add from: ' + (d.missingCats.slice(0,3).join(', ') || 'any category')]
    : ['Excellent — target met!'];
  if (d.foundLinkers.length === 0) linkerGood = [];
  if (d.foundLinkers.length >= d.linkerTarget) linkerIss = [];

  // Vocab positives/issues
  var vocGood = d.foundVocab.length > 0
    ? ['Unit vocabulary used: <b>' + d.foundVocab.join(', ') + '</b>'] : [];
  var vocIss  = d.foundVocab.length < d.vocabTarget
    ? ['Try including: ' + d.unusedVocab.map(function(v){ return '<b>' + v.w + '</b> (' + v.d + ')'; }).join(' · ')]
    : [];
  if (d.foundVocab.length === 0) vocGood = ['No unit vocabulary words detected — try to include some!'];

  // Structure
  var strGood = d.str.found.length > 0
    ? ['Structural elements detected (' + d.str.found.length + '/' + (d.str.found.length + d.str.missing.length) + '): ' + d.str.found.map(function(f){ return '<b>' + f.split('—')[0].trim() + '</b>'; }).slice(0,4).join(', ')]
    : [];
  var strIss  = d.str.missing.slice(0,4);

  var linkerColor = d.linkerScore >= 16 ? '#1A7F8E' : d.linkerScore >= 10 ? '#E07B39' : '#C62828';
  var vocColor    = d.vocabScore  >= 16 ? '#2E7D32'  : d.vocabScore  >= 10 ? '#E07B39' : '#C62828';
  var strColor    = d.str.score   >= 16 ? '#1B3A6B'  : d.str.score   >= 10 ? '#E07B39' : '#C62828';
  var wcColor     = d.wcScore     >= 16 ? '#2E7D32'  : d.wcScore     >= 10 ? '#E07B39' : '#C62828';
  var regColor    = d.reg.score   >= 16 ? '#6A1B9A'  : d.reg.score   >= 10 ? '#E07B39' : '#C62828';

  panel.innerHTML =
    // ── Score header ──
    '<div class="score-header">' +
      '<div class="score-big">' +
        '<div class="score-num" style="color:' + d.gradeColor + ';">' + d.total + '</div>' +
        '<div class="score-outof">/ 100</div>' +
      '</div>' +
      '<div style="flex:1;">' +
        '<div style="font-size:1.4rem;font-weight:800;color:' + d.gradeColor + ';">' + gradeEmoji + ' Grade ' + d.grade + ' — ' + gradeMsg + '</div>' +
        '<div style="font-size:0.83rem;color:#64748B;margin-top:4px;">+' + d.earnedXP + ' XP earned &nbsp;·&nbsp; ' + d.wCount + ' words written</div>' +
        '<div class="score-cats">' + catsHtml + '</div>' +
        '<div class="score-bar-wrap"><div class="score-bar-fill" style="width:' + d.total + '%;background:' + d.gradeColor + ';"></div></div>' +
      '</div>' +
    '</div>' +

    // ── Five feedback categories ──
    feedbackCatHTML('📊 Word Count',       d.wcScore,     wcColor,    [d.wcMsg], []) +
    feedbackCatHTML('🔗 Linking Devices',  d.linkerScore, linkerColor, linkerGood, linkerIss) +
    feedbackCatHTML('📚 Unit Vocabulary',  d.vocabScore,  vocColor,    vocGood,    vocIss) +
    feedbackCatHTML('🎯 Language Register', d.reg.score,  regColor,    d.reg.good, d.reg.issues) +
    feedbackCatHTML('📋 Structure',         d.str.score,  strColor,    strGood,    strIss) +

    // ── Action buttons ──
    '<div style="text-align:center;margin-top:20px;display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">' +
      '<button class="btn btn-primary" onclick="document.getElementById(\'practiceFeedbackPanel\').style.display=\'none\';document.getElementById(\'practiceTextarea\').focus();" style="background:var(--navy)">✏️ Keep Writing</button>' +
      '<button class="btn btn-outline" onclick="analyzeWriting()" style="--c:var(--navy)">🔄 Re-analyse</button>' +
      '<button class="btn btn-outline" onclick="resetPractice()" style="--c:var(--navy)">← New Task</button>' +
    '</div>';

  panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
  if (d.grade === 'A') launchConfetti();
}

