            <div class="tips-box" style="margin-bottom:10px">
              <h4 style="color:${task.color}">✔ DO</h4>
              <ul class="tips-list">${dosList}</ul>
            </div>
            <div class="donts-box">
              <h4>✘ DON'T</h4>
              <ul class="donts-list">${dontsList}</ul>
