// =====================================================
function addXP(amount) {
  xp += amount;
  const newLevel = Math.floor(xp / XP_PER_LEVEL) + 1;
  if (newLevel > level) {
    level = newLevel;
    showToast(`Level Up! You're now Level ${level} 🎉`, "gold");
    launchConfetti();
  }
  updateXPUI();
  document.getElementById('statXP').textContent = xp;
}
function updateXPUI() {
  document.getElementById('xpCount').textContent = xp;
  document.getElementById('levelBadge').textContent = `Lv ${level}`;
  const pct = ((xp % XP_PER_LEVEL) / XP_PER_LEVEL) * 100;
  document.getElementById('xpBar').style.width = pct + "%";
}

