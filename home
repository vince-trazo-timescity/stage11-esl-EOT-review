// WRITING TYPES QUIZ
// =====================================================
let writingQuestions = [], writingIndex = 0, writingScore = 0;

function generateWritingQuestions(count) {
  count = count || 12;
  var questions = [];
  var allTypes = WRITING_TASKS.map(function(t) { return t.type; });

  WRITING_TASKS.forEach(function(task) {
    function getWrong() {
      return allTypes.filter(function(t) { return t !== task.type; })
                     .sort(function() { return Math.random() - 0.5; }).slice(0, 3);
    }

    // Q type A: identify writing type from a DO rule
    if (task.dos.length > 0) {
      var item = task.dos[Math.floor(Math.random() * task.dos.length)];
      var opts = [task.type].concat(getWrong()).sort(function() { return Math.random() - 0.5; });
      questions.push({
        qtype: 'identify_type',
        hint: 'IDENTIFY THE WRITING TYPE',
        question: 'This is a rule for one writing type. Which type?',
        detail: '✔ DO: ' + item,
        correct: task.type,
        options: opts,
        color: task.color
      });
    }

    // Q type B: identify writing type from a DON'T rule
    if (task.donts.length > 0) {
      var ditem = task.donts[Math.floor(Math.random() * task.donts.length)];
      var dopts = [task.type].concat(getWrong()).sort(function() { return Math.random() - 0.5; });
      questions.push({
        qtype: 'identify_type',
        hint: 'IDENTIFY THE WRITING TYPE',
        question: 'Which writing type has this as a common mistake to avoid?',
        detail: '✘ AVOID: ' + ditem,
        correct: task.type,
        options: dopts,
        color: task.color
      });
    }

    // Q type C: is this item a DO or a DON'T for this specific writing type?
    var isDo = Math.random() > 0.5;
    var srcList = isDo ? task.dos : task.donts;
    if (srcList.length > 0) {
      var citem = srcList[Math.floor(Math.random() * srcList.length)];
      var correct2 = isDo ? '✔ DO this' : '✘ DON\'T do this';
      questions.push({
        qtype: 'do_or_dont',
        hint: task.type.toUpperCase(),
        question: 'For a ' + task.type + ', is this a DO or a DON\'T?',
        detail: '"' + citem + '"',
        correct: correct2,
        options: ['✔ DO this', '✘ DON\'T do this'],
        color: task.color
      });
    }

    // Q type D: identify writing type from a structure element
    if (task.structure.length > 0) {
      var sitem = task.structure[Math.floor(Math.random() * task.structure.length)];
      var sopts = [task.type].concat(getWrong()).sort(function() { return Math.random() - 0.5; });
      questions.push({
        qtype: 'identify_type',
        hint: 'IDENTIFY THE WRITING TYPE',
        question: 'Which writing type includes this structural element?',
        detail: '📋 ' + sitem,
        correct: task.type,
        options: sopts,
        color: task.color
      });
    }

    // Q type E: identify writing type from a writing tip
    if (task.tips.length > 0) {
      var titem = task.tips[Math.floor(Math.random() * task.tips.length)];
      var topts = [task.type].concat(getWrong()).sort(function() { return Math.random() - 0.5; });
      questions.push({
        qtype: 'identify_type',
        hint: 'IDENTIFY THE WRITING TYPE',
        question: 'This tip belongs to one writing type. Which one?',
        detail: '💡 ' + titem,
        correct: task.type,
        options: topts,
        color: task.color
      });
    }
  });

  return questions.sort(function() { return Math.random() - 0.5; })
                  .slice(0, Math.min(count, questions.length));
}

