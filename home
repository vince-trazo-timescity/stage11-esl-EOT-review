function setQuizUnit(uid) {
  const wrap = document.getElementById('quizPills');
  quizUnit = UNITS.find(u => u.id === uid) || UNITS[0];
  activatePill(wrap, uid);
  startQuiz();
}
function startQuiz() {
  const vocab = quizUnit.vocab;
  quizQuestions = generateQuestions(vocab, 10);
  quizIndex = 0;
  quizScore = 0;
  document.getElementById('quizResult').classList.remove('show');
  document.getElementById('quizContainer').style.display = '';
  document.getElementById('quizCard').style.display = '';
  document.getElementById('quizScoreMini').textContent = '0';
  renderQuestion();
}
function generateQuestions(vocab, count) {
  const shuffled = [...vocab].sort(() => Math.random() - 0.5);
  return shuffled.slice(0, Math.min(count, vocab.length)).map((correct, i) => {
    const others = vocab.filter(v => v.w !== correct.w).sort(() => Math.random() - 0.5).slice(0, 3);
    const options = [correct, ...others].sort(() => Math.random() - 0.5);
    const type = Math.random() > 0.5 ? 'def2word' : 'word2def';
    return { correct, options, type };
  });
}
function renderQuestion() {
  const q = quizQuestions[quizIndex];
  document.getElementById('quizCounter').textContent = `Question ${quizIndex + 1} of ${quizQuestions.length}`;
  document.getElementById('quizNextBtn').style.display = 'none';
  document.getElementById('quizFeedback').className = 'quiz-feedback';
  document.getElementById('quizFeedback').style.display = 'none';

  let questionText, hint;
  if (q.type === 'def2word') {
    questionText = q.correct.d;
    hint = "Which word matches this definition?";
  } else {
    questionText = `"${q.correct.e}"`;
    hint = `What does "${q.correct.w}" mean?`;
  }
  document.getElementById('quizWordHint').textContent = quizUnit.num.toUpperCase() + " — " + hint;
  document.getElementById('quizQuestion').textContent = questionText;

  const optionsEl = document.getElementById('quizOptions');
  optionsEl.innerHTML = '';
  q.options.forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'quiz-option';
    btn.style.setProperty('--c', quizUnit.color);
    btn.textContent = q.type === 'def2word' ? opt.w : opt.d;
    btn.onclick = () => checkAnswer(btn, opt, q);
    optionsEl.appendChild(btn);
  });
}
function checkAnswer(btn, selected, q) {
  const options = document.querySelectorAll('.quiz-option');
  options.forEach(b => b.classList.add('disabled'));
  const feedback = document.getElementById('quizFeedback');
  feedback.style.display = 'block';

  if (selected.w === q.correct.w) {
    btn.classList.add('correct');
    feedback.className = 'quiz-feedback show correct';
    feedback.textContent = `✔ Correct! "${q.correct.w}" — ${q.correct.d}`;
    quizScore++;
    document.getElementById('quizScoreMini').textContent = quizScore;
    addXP(10);
    showToast("+10 XP! ⭐", "gold");
  } else {
    btn.classList.add('wrong');
    options.forEach(b => {
      if (b.textContent === (q.type === 'def2word' ? q.correct.w : q.correct.d)) b.classList.add('correct');
    });
    feedback.className = 'quiz-feedback show wrong';
    feedback.textContent = `✘ Not quite. The answer was "${q.correct.w}" — ${q.correct.d}`;
  }

  document.getElementById('quizNextBtn').style.display = 'inline-flex';
  if (quizIndex === quizQuestions.length - 1) {
    document.getElementById('quizNextBtn').textContent = 'See Results →';
  }
}
function nextQuestion() {
  quizIndex++;
  if (quizIndex >= quizQuestions.length) {
    showQuizResult();
  } else {
    renderQuestion();
  }
}
function showQuizResult() {
  document.getElementById('quizCard').style.display = 'none';
  document.getElementById('quizNextBtn').style.display = 'none';
  const panel = document.getElementById('quizResult');
  panel.classList.add('show');
  const pct = Math.round((quizScore / quizQuestions.length) * 100);
  const bonusXP = pct >= 80 ? 50 : pct >= 60 ? 25 : 10;
  addXP(bonusXP);
  if (pct >= 90) { launchConfetti(); }
  const emojis = pct>=90?"🎉":pct>=70?"😊":pct>=50?"👍":"💪";
  const titles = pct>=90?"Outstanding!":pct>=70?"Well done!":pct>=50?"Good effort!":"Keep practising!";
  document.getElementById('resultEmoji').textContent = emojis;
  document.getElementById('resultTitle').textContent = titles;
  document.getElementById('resultScore').textContent = `You scored ${quizScore} / ${quizQuestions.length} (${pct}%)`;
  document.getElementById('resultXP').textContent = `+${bonusXP} Bonus XP earned!`;
}
function retryQuiz() {
  document.getElementById('quizResult').classList.remove('show');
  document.getElementById('quizContainer').style.display = '';
  document.getElementById('quizCard').style.display = '';
  startQuiz();
}

