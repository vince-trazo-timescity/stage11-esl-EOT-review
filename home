
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stage 11 ESL – Interactive Revision Hub</title>
<style>
/* =====================================================
   RESET & ROOT
   ===================================================== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --navy:   #1B3A6B;
  --teal:   #1A7F8E;
  --gold:   #D4A017;
  --orange: #E07B39;
  --green:  #2E7D32;
  --purple: #6A1B9A;
  --blue:   #1565C0;
  --enviro: #0277BD;
  --food:   #558B2F;
  --pink:   #AD1457;
  --indigo: #4527A0;
  --white:  #FFFFFF;
  --light:  #F0F4F8;
  --mid:    #CBD5E1;
  --dark:   #1E293B;
  --text:   #334155;
  --shadow: 0 4px 20px rgba(0,0,0,0.13);
}
html { scroll-behavior: smooth; }
body {
  font-family: "Segoe UI", Calibri, system-ui, sans-serif;
  background: #E8EDF4;
  color: var(--text);
  min-height: 100vh;
  font-size: 15px;
}

/* =====================================================
   TOP BAR
   ===================================================== */
.topbar {
  background: var(--navy);
  color: white;
  position: sticky; top: 0; z-index: 200;
  box-shadow: 0 2px 12px rgba(0,0,0,0.35);
}
.topbar-inner {
  max-width: 1100px; margin: 0 auto;
  display: flex; align-items: center; gap: 12px;
  padding: 10px 20px;
}
.site-title { font-size: 1.1rem; font-weight: 800; color: var(--gold); white-space: nowrap; }
.site-sub   { font-size: 0.75rem; color: #8BAFC8; margin-left: 4px; }

/* XP BAR */
.xp-area {
  margin-left: auto; display: flex; align-items: center; gap: 12px;
}
.xp-label { font-size: 0.8rem; color: #A8C4D4; }
.xp-count { font-size: 1rem; font-weight: 800; color: var(--gold); min-width: 48px; text-align: right; }
.xp-bar-wrap {
  width: 120px; height: 10px; background: rgba(255,255,255,0.15);
  border-radius: 5px; overflow: hidden;
}
.xp-bar-fill {
  height: 100%; background: linear-gradient(90deg, var(--gold), #FFD700);
  border-radius: 5px; transition: width 0.6s cubic-bezier(.4,2,.6,1);
  width: 0%;
}
.level-badge {
  background: var(--gold); color: var(--navy);
  font-weight: 800; font-size: 0.75rem;
  padding: 3px 10px; border-radius: 12px;
}

/* =====================================================
   MAIN NAV (TABS)
   ===================================================== */
.main-nav {
  background: #102A52;
  display: flex; overflow-x: auto; gap: 2px;
  scrollbar-width: none;
}
.main-nav::-webkit-scrollbar { display: none; }
.nav-tab {
  padding: 10px 18px; white-space: nowrap; cursor: pointer;
  font-size: 0.82rem; font-weight: 700; color: #8BAFC8;
  border-bottom: 3px solid transparent;
  transition: all 0.2s; background: none; border-top: none; border-left: none; border-right: none;
  letter-spacing: 0.3px;
}
.nav-tab:hover { color: white; background: rgba(255,255,255,0.07); }
.nav-tab.active { color: var(--gold); border-bottom-color: var(--gold); background: rgba(255,255,255,0.06); }

/* =====================================================
   PAGE CONTAINER
   ===================================================== */
.page { display: none; max-width: 1000px; margin: 0 auto; padding: 28px 16px 80px; }
.page.active { display: block; }

/* =====================================================
   HOME PAGE
   ===================================================== */
.welcome-banner {
  background: linear-gradient(135deg, var(--navy) 0%, #1A5276 100%);
  border-radius: 16px; padding: 36px 32px; color: white; margin-bottom: 28px;
  position: relative; overflow: hidden;
}
.welcome-banner::before {
  content: "📚";
  position: absolute; right: 28px; top: 50%; transform: translateY(-50%);
  font-size: 5rem; opacity: 0.15;
}
.welcome-banner h1 { font-size: 1.8rem; color: var(--gold); margin-bottom: 6px; }
.welcome-banner p  { color: #A8C4D4; font-size: 0.92rem; max-width: 600px; line-height: 1.6; }

.unit-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 14px; margin-bottom: 28px;
}
.unit-card {
  background: white; border-radius: 14px; padding: 18px 16px;
  cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;
  border-left: 5px solid var(--c); box-shadow: var(--shadow);
  position: relative; overflow: hidden;
}
.unit-card::after {
  content: "→"; position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
  font-size: 1.2rem; color: var(--c); opacity: 0.4; transition: opacity 0.2s, right 0.2s;
}
.unit-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,0,0,0.16); }
.unit-card:hover::after { opacity: 0.8; right: 10px; }
.unit-num  { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--c); letter-spacing: 0.8px; }
.unit-name { font-size: 0.95rem; font-weight: 700; color: var(--dark); margin: 4px 0 8px; }
.unit-meta { font-size: 0.75rem; color: #94A3B8; }
.unit-meta b { color: var(--c); }

.stats-row {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px;
}
.stat-box {
  background: white; border-radius: 12px; padding: 16px;
  text-align: center; box-shadow: var(--shadow);
}
.stat-num { font-size: 1.8rem; font-weight: 800; color: var(--navy); }
.stat-lbl { font-size: 0.75rem; color: #94A3B8; margin-top: 2px; }

/* =====================================================
   SECTION HEADERS
   ===================================================== */
.section-header {
  display: flex; align-items: center; gap: 12px; margin-bottom: 20px;
}
.section-badge {
  background: var(--c, var(--navy)); color: white;
  padding: 6px 14px; border-radius: 20px; font-size: 0.75rem; font-weight: 800;
  white-space: nowrap;
}
.section-title { font-size: 1.3rem; font-weight: 800; color: var(--dark); }
.section-sub   { font-size: 0.82rem; color: #94A3B8; margin-top: 2px; }

/* =====================================================
   UNIT SELECTOR (inside vocabulary page)
   ===================================================== */
.unit-pills {
  display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px;
}
.unit-pill {
  padding: 7px 16px; border-radius: 20px; border: 2px solid var(--c, var(--navy));
  background: white; color: var(--c, var(--navy)); font-size: 0.8rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s;
}
.unit-pill:hover, .unit-pill.active {
  background: var(--c, var(--navy)); color: white;
}

/* =====================================================
   FLASHCARD
   ===================================================== */
.flashcard-area { margin-bottom: 28px; }
.fc-controls { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
.fc-progress { font-size: 0.82rem; color: #64748B; }
.fc-progress b { color: var(--c, var(--navy)); }

.flashcard-scene {
  width: 100%; height: 220px;
  perspective: 1200px; cursor: pointer; margin-bottom: 14px;
}
.flashcard-inner {
  width: 100%; height: 100%; position: relative;
  transform-style: preserve-3d; transition: transform 0.55s cubic-bezier(.4,0,.2,1);
}
.flashcard-scene.flipped .flashcard-inner { transform: rotateY(180deg); }
.flashcard-front, .flashcard-back {
  position: absolute; width: 100%; height: 100%;
  border-radius: 18px; padding: 28px 32px; backface-visibility: hidden;
  display: flex; flex-direction: column; justify-content: center;
  box-shadow: var(--shadow);
}
.flashcard-front {
  background: linear-gradient(135deg, var(--c, var(--navy)), color-mix(in srgb, var(--c, var(--navy)) 80%, black 20%));
  color: white; align-items: center; text-align: center;
}
.flashcard-back {
  background: white; transform: rotateY(180deg);
  border: 2px solid var(--c, var(--navy));
}
.fc-word { font-size: 2rem; font-weight: 800; line-height: 1.1; margin-bottom: 8px; }
.fc-hint { font-size: 0.78rem; opacity: 0.7; }
.fc-unit-tag { font-size: 0.68rem; background: rgba(255,255,255,0.2); padding: 3px 10px; border-radius: 10px; margin-bottom: 10px; display: inline-block; }
.fc-def { font-size: 1rem; color: var(--dark); line-height: 1.55; margin-bottom: 10px; }
.fc-example { font-size: 0.82rem; color: #64748B; font-style: italic; border-left: 3px solid var(--c, var(--navy)); padding-left: 10px; }

.fc-btn-row { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
.btn {
  padding: 9px 22px; border-radius: 24px; border: none; cursor: pointer;
  font-size: 0.85rem; font-weight: 700; transition: all 0.18s;
  display: inline-flex; align-items: center; gap: 6px;
}
.btn-primary { background: var(--c, var(--navy)); color: white; }
.btn-primary:hover { filter: brightness(1.15); transform: translateY(-1px); }
.btn-outline { background: white; color: var(--c, var(--navy)); border: 2px solid var(--c, var(--navy)); }
.btn-outline:hover { background: var(--c, var(--navy)); color: white; }
.btn-success { background: var(--green); color: white; }
.btn-success:hover { filter: brightness(1.1); }
.btn-sm { padding: 6px 14px; font-size: 0.78rem; }

/* =====================================================
   QUIZ
   ===================================================== */
.quiz-card {
  background: white; border-radius: 18px; padding: 28px; margin-bottom: 18px;
  box-shadow: var(--shadow);
}
.quiz-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
.quiz-counter { font-size: 0.8rem; color: #94A3B8; }
.quiz-score-mini { font-size: 0.8rem; background: var(--light); padding: 4px 10px; border-radius: 10px; color: var(--dark); font-weight: 700; }
.quiz-word {
  font-size: 0.9rem; color: #64748B; margin-bottom: 6px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;
}
.quiz-question {
  font-size: 1.1rem; font-weight: 700; color: var(--dark); margin-bottom: 20px; line-height: 1.45;
}
.quiz-options { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.quiz-option {
  padding: 12px 16px; border-radius: 12px; border: 2px solid #E2E8F0;
  background: #F8FAFC; cursor: pointer; transition: all 0.18s;
  font-size: 0.88rem; font-weight: 600; color: var(--dark); text-align: left;
}
.quiz-option:hover:not(.disabled) { border-color: var(--c, var(--navy)); background: color-mix(in srgb, var(--c, var(--navy)) 8%, white); }
.quiz-option.correct  { border-color: var(--green); background: #E8F5E9; color: var(--green); }
.quiz-option.wrong    { border-color: #C62828; background: #FFEBEE; color: #C62828; }
.quiz-option.disabled { cursor: default; opacity: 0.7; }
.quiz-feedback {
  margin-top: 14px; padding: 10px 14px; border-radius: 10px;
  font-size: 0.88rem; font-weight: 600; display: none;
}
.quiz-feedback.show { display: block; }
.quiz-feedback.correct { background: #E8F5E9; color: #1B5E20; }
.quiz-feedback.wrong   { background: #FFEBEE; color: #B71C1C; }

.quiz-result-panel {
  background: white; border-radius: 18px; padding: 36px; text-align: center;
  box-shadow: var(--shadow); display: none;
}
.quiz-result-panel.show { display: block; }
.result-emoji { font-size: 3.5rem; margin-bottom: 10px; }
.result-title { font-size: 1.5rem; font-weight: 800; color: var(--dark); margin-bottom: 6px; }
.result-score { font-size: 1rem; color: #64748B; margin-bottom: 20px; }
.result-xp    { font-size: 0.9rem; color: var(--gold); font-weight: 800; margin-bottom: 20px; }

/* =====================================================
   VOCAB TABLE
   ===================================================== */
.vocab-table { width: 100%; border-collapse: collapse; background: white; border-radius: 14px; overflow: hidden; box-shadow: var(--shadow); margin-bottom: 22px; }
.vocab-table th { padding: 12px 16px; text-align: left; color: white; background: var(--c, var(--navy)); font-size: 0.82rem; font-weight: 700; }
.vocab-table td { padding: 11px 16px; border-bottom: 1px solid #F1F5F9; font-size: 0.88rem; vertical-align: top; }
.vocab-table tr:last-child td { border-bottom: none; }
.vocab-table tr:hover td { background: #F8FAFC; }
.vocab-word { font-weight: 700; color: var(--c, var(--navy)); }
.vocab-def  { color: var(--text); }
.vocab-extra { font-size: 0.78rem; color: #94A3B8; font-style: italic; margin-top: 3px; }

/* =====================================================
   WRITING PAGE
   ===================================================== */
.writing-task-card {
  background: white; border-radius: 16px; margin-bottom: 20px;
  box-shadow: var(--shadow); overflow: hidden;
}
.wtc-header {
  padding: 16px 22px; color: white;
  background: var(--c, var(--navy));
  display: flex; justify-content: space-between; align-items: flex-start;
}
.wtc-unit { font-size: 0.72rem; opacity: 0.8; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
.wtc-type { font-size: 1.1rem; font-weight: 800; margin: 2px 0; }
.wtc-length { font-size: 0.75rem; opacity: 0.75; }
.wtc-body { padding: 20px 22px; }
.wtc-prompt {
  background: #F0F4F8; border-radius: 10px; padding: 14px 16px;
  font-size: 0.9rem; color: var(--dark); margin-bottom: 16px;
  border-left: 4px solid var(--c, var(--navy));
  font-style: italic;
}
.tips-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.tips-box, .donts-box {
  border-radius: 10px; padding: 14px; font-size: 0.82rem;
}
.tips-box  { background: #FFFDE7; border: 1px solid #FBC02D; }
.donts-box { background: #FFEBEE; border: 1px solid #EF9A9A; }
.tips-box h4  { color: #F57F17; margin-bottom: 8px; }
.donts-box h4 { color: #C62828; margin-bottom: 8px; }
.tips-list { list-style: none; }
.tips-list li { padding: 3px 0; color: #37474F; }
.tips-list li::before { content: "✔  "; color: var(--green); }
.donts-list { list-style: none; }
.donts-list li { padding: 3px 0; color: #37474F; }
.donts-list li::before { content: "✘  "; color: #C62828; }

.checklist-area { margin-top: 16px; }
.checklist-area h4 { font-size: 0.88rem; font-weight: 700; color: var(--dark); margin-bottom: 10px; }
.checklist-item {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 12px; border-radius: 8px; margin-bottom: 6px;
  background: #F8FAFC; cursor: pointer; transition: background 0.2s;
  font-size: 0.85rem; user-select: none;
}
.checklist-item:hover { background: #EEF2F7; }
.checklist-item.checked { background: #E8F5E9; }
.checklist-item input[type=checkbox] { accent-color: var(--green); width: 16px; height: 16px; }
.checklist-item.checked .cl-label { color: var(--green); text-decoration: line-through; opacity: 0.7; }
.checklist-progress { margin-top: 10px; }
.cl-bar-wrap { height: 6px; background: #E2E8F0; border-radius: 3px; overflow: hidden; }
.cl-bar-fill { height: 100%; background: var(--green); border-radius: 3px; transition: width 0.4s; }
.cl-percent { font-size: 0.75rem; color: #64748B; margin-top: 4px; }

/* =====================================================
   LANGUAGE REFERENCE PAGE
   ===================================================== */
.linker-tabs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
.linker-tab {
  padding: 6px 14px; border-radius: 16px; border: 2px solid #CBD5E1;
  background: white; font-size: 0.78rem; font-weight: 700; cursor: pointer;
  transition: all 0.2s; color: var(--text);
}
.linker-tab:hover, .linker-tab.active { background: var(--navy); color: white; border-color: var(--navy); }

.linker-section { display: none; }
.linker-section.active { display: block; }

.linker-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; margin-bottom: 18px; }
.linker-card {
  background: white; border-radius: 12px; padding: 14px; box-shadow: var(--shadow);
  border-top: 4px solid var(--c, var(--navy));
  cursor: pointer; transition: transform 0.18s;
}
.linker-card:hover { transform: translateY(-2px); }
.linker-word { font-size: 0.95rem; font-weight: 800; color: var(--c, var(--navy)); margin-bottom: 6px; }
.linker-func { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px; color: #94A3B8; margin-bottom: 8px; }
.linker-example { font-size: 0.8rem; color: var(--text); font-style: italic; line-height: 1.45; }

.ref-words-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.ref-word-card {
  background: white; border-radius: 12px; padding: 14px 16px; box-shadow: var(--shadow);
  border-left: 4px solid var(--teal);
}
.rw-word { font-size: 0.95rem; font-weight: 800; color: var(--teal); margin-bottom: 6px; }
.rw-example { font-size: 0.82rem; color: var(--text); font-style: italic; }

/* =====================================================
   TOASTS / NOTIFICATIONS
   ===================================================== */
.toast-wrap {
  position: fixed; top: 70px; right: 16px; z-index: 999;
  display: flex; flex-direction: column; gap: 8px;
  pointer-events: none;
}
.toast {
  background: var(--navy); color: white;
  padding: 10px 18px; border-radius: 10px;
  font-size: 0.85rem; font-weight: 700;
  transform: translateX(120%); transition: transform 0.35s cubic-bezier(.4,0,.2,1);
  box-shadow: var(--shadow);
}
.toast.show { transform: translateX(0); }
.toast.gold  { background: var(--gold); color: var(--navy); }
.toast.green { background: var(--green); }

/* =====================================================
   CONFETTI
   ===================================================== */
.confetti-wrap { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 998; }
.confetto {
  position: absolute; width: 10px; height: 10px; border-radius: 2px;
  animation: confetto-fall 2.5s ease-in forwards;
}
@keyframes confetto-fall {
  0%   { transform: translateY(-20px) rotate(0deg); opacity: 1; }
  100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
}

/* =====================================================
   UTILITIES & MISC
   ===================================================== */
.divider { height: 1px; background: #E2E8F0; margin: 24px 0; }
.tag {
  display: inline-block; padding: 2px 10px; border-radius: 10px;
  font-size: 0.7rem; font-weight: 700; background: var(--light); color: var(--text);
}
.empty-state {
  text-align: center; padding: 40px; color: #94A3B8;
  font-size: 1rem;
}

@media (max-width: 600px) {
  .quiz-options { grid-template-columns: 1fr; }
  .tips-grid    { grid-template-columns: 1fr; }
  .ref-words-grid { grid-template-columns: 1fr; }
  .welcome-banner { padding: 24px 20px; }
  .welcome-banner h1 { font-size: 1.4rem; }
  .topbar-inner { flex-wrap: wrap; gap: 8px; }
  .xp-bar-wrap { width: 80px; }
}

/* =====================================================
   QUIZ MODE SELECTOR
   ===================================================== */
.quiz-mode-btns {
  display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 24px;
}
.quiz-mode-btn {
  padding: 10px 22px; border-radius: 24px; border: 2px solid #CBD5E1;
  background: white; color: var(--text); font-size: 0.85rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s;
}
.quiz-mode-btn:hover { border-color: var(--navy); color: var(--navy); }
.quiz-mode-btn.active { background: var(--navy); color: white; border-color: var(--navy); }

.quiz-type-banner {
  border-radius: 14px; padding: 18px 22px; margin-bottom: 20px; color: white;
}
.quiz-type-banner h3 { font-size: 1rem; font-weight: 800; margin-bottom: 4px; }
.quiz-type-banner p  { font-size: 0.83rem; opacity: 0.85; }

.quiz-example-box {
  font-style: italic; color: #64748B; font-size: 0.83rem;
  margin-bottom: 16px; padding: 10px 14px;
  background: #F0F4F8; border-radius: 8px;
  border-left: 3px solid #1B3A6B;
  min-height: 0;
}

/* =====================================================
   WRITING PRACTICE PAGE
   ===================================================== */
.ptask-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(200px,1fr));
  gap: 14px; margin-bottom: 24px;
}
.ptask-card {
  background: white; border-radius: 14px; padding: 18px 16px;
  cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;
  border-top: 5px solid var(--c, var(--navy)); box-shadow: var(--shadow);
}
.ptask-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,0,0,0.16); }
.ptask-type { font-size: 1rem; font-weight: 800; color: var(--c, var(--navy)); margin-bottom: 6px; }
.ptask-unit { font-size: 0.78rem; color: #64748B; margin-bottom: 8px; line-height: 1.4; }
.ptask-len  { font-size: 0.72rem; background: var(--light); padding: 3px 10px; border-radius: 10px; display: inline-block; color: var(--text); font-weight: 700; }

.practice-banner {
  border-radius: 14px; padding: 18px 22px; margin-bottom: 20px; color: white;
}
.practice-prompt-box {
  background: rgba(255,255,255,0.15); border-radius: 10px;
  padding: 12px 16px; font-style: italic; font-size: 0.88rem; margin-top: 10px; line-height: 1.55;
}
.practice-textarea {
  width: 100%; min-height: 340px; padding: 18px;
  font-size: 0.95rem; line-height: 1.75; color: var(--dark);
  border: 2px solid #E2E8F0; border-radius: 14px; resize: vertical;
  transition: border-color 0.2s;
  font-family: "Segoe UI", Calibri, system-ui, sans-serif;
  background: white; box-shadow: var(--shadow);
}
.practice-textarea:focus { outline: none; border-color: var(--navy); }
.practice-meta {
  display: flex; justify-content: space-between; align-items: center;
  margin: 12px 0 18px; flex-wrap: wrap; gap: 10px;
}
.wc-display {
  font-size: 0.88rem; font-weight: 700; color: #94A3B8;
