function switchQuizMode(mode, btn) {
  document.querySelectorAll('.quiz-mode-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('quizModeVocab').style.display   = mode === 'vocab'   ? '' : 'none';
  document.getElementById('quizModeLinker').style.display  = mode === 'linker'  ? '' : 'none';
  document.getElementById('quizModeWriting').style.display = mode === 'writing' ? '' : 'none';
  if (mode === 'linker'  && linkerQuestions.length === 0) startLinkerQuiz();
  if (mode === 'writing' && writingQuestions.length === 0) startWritingQuiz();
}

// =====================================================
// LINKING DEVICES QUIZ
// =====================================================
const LINKER_CATS_DISPLAY = {
  adding:      "➕ Adding Information",
  contrasting: "↔ Contrasting Ideas",
  cause:       "⚡ Cause & Effect",
  sequencing:  "🔢 Sequencing",
  examples:    "📌 Giving Examples",
  opinion:     "💬 Expressing Opinion",
  structures:  "🏗️ Complex Structures"
};

// Build flat linker array (skip reference words which have a different format)
const ALL_LINKERS_FLAT = [];
Object.entries(LINKERS).forEach(([cat, items]) => {
  if (cat === 'reference') return;
  items.forEach(item => ALL_LINKERS_FLAT.push(Object.assign({}, item, { cat })));
});

let linkerQuestions = [], linkerIndex = 0, linkerScore = 0;

function generateLinkerQuestions(count) {
  count = count || 10;
  const items = ALL_LINKERS_FLAT;
  const shuffled = items.slice().sort(() => Math.random() - 0.5);
  const selected = shuffled.slice(0, Math.min(count, items.length));

  return selected.map(function(correct) {
    var type = Math.random() > 0.5 ? 'func2word' : 'word2cat';

    if (type === 'func2word') {
      // Show function → pick the correct linker word
      var wrong = items.filter(function(l) { return l.w !== correct.w; })
                       .sort(function() { return Math.random() - 0.5; }).slice(0, 3);
      var options = [correct.w].concat(wrong.map(function(l) { return l.w; }))
                               .sort(function() { return Math.random() - 0.5; });
      return {
        type: 'func2word',
        question: 'Which linking device is used for: "' + correct.f + '"?',
        example: 'e.g. ' + correct.e,
        correct: correct.w,
        options: options
      };
    } else {
      // Show word → pick the correct category
      var catLabel = LINKER_CATS_DISPLAY[correct.cat];
      var wrongCats = Object.values(LINKER_CATS_DISPLAY)
                            .filter(function(c) { return c !== catLabel; })
                            .sort(function() { return Math.random() - 0.5; }).slice(0, 3);
      var options2 = [catLabel].concat(wrongCats).sort(function() { return Math.random() - 0.5; });
      return {
        type: 'word2cat',
        question: '"' + correct.w + '" — which category does this linker belong to?',
        example: 'e.g. ' + correct.e,
        correct: catLabel,
        options: options2
      };
    }
  });
}

